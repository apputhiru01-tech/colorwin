# ── Server ──────────────────────────────────────────
PORT=3000

# ── MongoDB ─────────────────────────────────────────
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/colorwin

# ── JWT ──────────────────────────────────────────────
# Any long random string (keep secret!)
JWT_SECRET=colorwin_super_secret_key_change_this_in_production_2024

# ── Admin Login ──────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@9999

# ── Email OTP (Gmail) ────────────────────────────────
# 1. Go to Google Account → Security → 2-Step Verification
# 2. App Passwords → Generate password for "Mail"
# 3. Use that 16-char password below (NOT your Gmail password)
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Google OAuth ─────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client
# 3. Authorized JS origins: http://localhost:3000
# 4. Copy Client ID below
GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# ── Razorpay (UPI Deposits) ──────────────────────────
# 1. Sign up at https://razorpay.com
# 2. Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx

# ── App URL (for production deployment) ─────────────
APP_URL=http://localhost:3000
